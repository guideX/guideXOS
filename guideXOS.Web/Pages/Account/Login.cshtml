@page
@model guideXOS.Web.Pages.Account.LoginModel
<div class="login-panel">
  <h2>guideXOS Web Login</h2>
  <form id="loginForm">
    <label>Username</label>
    <input id="user" name="user" autocomplete="username" />
    <label>Password</label>
    <input id="pass" name="pass" type="password" autocomplete="current-password" />
    <button type="submit">Login</button>
    <button type="button" id="registerBtn">Register</button>
  </form>
  <div id="loginMsg"></div>
</div>
<script>
(function(){
  async function callAuth(path, payload){
    const resp = await fetch('/v1/auth/'+path,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
    return await resp.json();
  }
  document.getElementById('loginForm').addEventListener('submit', async (e)=>{
    e.preventDefault();
    const user = document.getElementById('user').value;
    const pass = document.getElementById('pass').value;
    const r = await callAuth('login',{username:user,password:pass});
    const msg = document.getElementById('loginMsg');
    if(r && r.success){
      localStorage.setItem('gx_token', r.loginGuid);
      location.href = '/Desktop';
    }else{
      msg.textContent = r && r.message ? r.message : 'Login failed';
    }
  });
  document.getElementById('registerBtn').addEventListener('click', async ()=>{
    const user = document.getElementById('user').value;
    const pass = document.getElementById('pass').value;
    const r = await callAuth('register',{username:user,password:pass});
    const msg = document.getElementById('loginMsg');
    if(r && r.success){ msg.textContent = 'Registered. You can login now.'; }
    else { msg.textContent = r && r.message ? r.message : 'Register failed'; }
  });
})();
</script>
